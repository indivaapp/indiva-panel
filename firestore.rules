rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Adminin e-postası — Auth'ta oluşturduğun hesabın e-postası
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'indivaapp@gmail.com';
    }

    // İlanlar: herkes okur; sadece admin ekler/siler/düzenler;
    // herkes YALNIZCA oy sayacını +1 artırabilir
    match /discounts/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || ( request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activeVotes'])
             && request.resource.data.activeVotes == resource.data.get('activeVotes', 0) + 1 )
        || ( request.resource.data.diff(resource.data).affectedKeys().hasOnly(['expiredVotes'])
             && request.resource.data.expiredVotes == resource.data.get('expiredVotes', 0) + 1 );
    }

    // Hikayeler & broşürler: herkes okur, sadece admin yazar
    match /influencerStories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /circulars/{market}/brochures/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Kullanıcı form gönderimleri: app herkese açık OLUŞTURUR, sadece admin okur/yönetir
    match /pendingDiscounts/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /adRequests/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // FCM token: app yazar, sadece admin okur
    match /fcmTokens/{token} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // Bildirimler: sadece admin (Cloud Functions admin SDK ile zaten kuralları atlar)
    match /notifications/{id}            { allow read, write: if isAdmin(); }
    match /scheduled_notifications/{id}  { allow read, write: if isAdmin(); }

    // Trendyol scraper: kontrol belgeleri + onay bekleyen ürünler (yalnızca yönetici)
    match /scraper_control/{id}  { allow read, write: if isAdmin(); }
    match /trendyol_staging/{id} { allow read, write: if isAdmin(); }

    // Sosyal medya içerik kuyruğu: otomatik üretilen Instagram içerikleri (yalnızca yönetici)
    match /social_content_queue/{id} { allow read, write: if isAdmin(); }

    // AI kullanım/maliyet istatistikleri — sadece Admin SDK (scripts, Cloud
    // Functions, Vercel proxy) yazar; o yazmalar zaten rules'u atlar.
    // Client SDK üzerinden asla yazılmamalı; panel sadece okur.
    match /aiUsage/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Zamanlı sosyal medya AI önerisi (scripts/auto-social-ai-suggest.js Admin
    // SDK ile yazar, rules'u atlar). Panel sadece okur ve "opened" alanını
    // işaretlemek için update eder (services/firebase.ts:markAiSocialSuggestionOpened).
    match /social_content_ai_suggestions/{id} {
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow create, delete: if false;
    }
  }
}
