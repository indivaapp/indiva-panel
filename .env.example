# INDIVA Panel - Environment Variables Example
# Copy this file to .env and fill in the values.
# DO NOT commit .env or any file containing real keys to version control.

# --- AI Services ---
# Google Gemini API Key
VITE_GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter API Key (Alternative for Gemini/Claude/GPT)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key (Fast Inference)
VITE_GROQ_API_KEY=your_groq_api_key_here

# --- Infrastructure ---
# GitHub Personal Access Token (with 'workflow' scope)
VITE_GITHUB_TOKEN=your_github_token_here

# Firebase Service Account (JSON string for CI/CD)
# In local development, use firebase-service-account.json file (git-ignored)
FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'
